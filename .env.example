# =============================================================================
# Trading Bot Pro - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ─── Server Ports ────────────────────────────────────────────────────────────
PORT=3001                          # Analytics dashboard port
BOT_PORT=3000                      # Trading bot API port
CHATBOT_PORT=3002                  # VA chatbot server port

# ─── Database ────────────────────────────────────────────────────────────────
DB_PATH=./data/trading.db          # SQLite database file path

# ─── Account Settings ────────────────────────────────────────────────────────
ACCOUNT_SIZE=100000                # Account size in USD
MAX_RISK_PER_TRADE=0.02            # Max risk per trade as decimal (0.02 = 2%)

# ─── External APIs (for real market data) ────────────────────────────────────
# Get your key at: https://alphaadvantage.co
ALPHA_VANTAGE_API_KEY=your_key_here

# Get your key at: https://polygon.io
POLYGON_API_KEY=your_key_here

# Get your key at: https://iexcloud.io
IEX_CLOUD_API_KEY=your_key_here

# ─── Notifications ────────────────────────────────────────────────────────────
# Slack: Create a webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord: Create a webhook in channel settings → Integrations
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                     # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=text                    # text | json

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*                      # Restrict in production: https://yourdomain.com

# ─── Backtester ──────────────────────────────────────────────────────────────
BACKTEST_LOOKBACK_DAYS=365         # Days of history to use in backtests
BACKTEST_UNIVERSE_SIZE=100         # Number of stocks to scan

# ─── Paper Trading ───────────────────────────────────────────────────────────
PAPER_TRADING_MODE=true            # Always true unless you have a live broker API

# ─── Trade Log Files ─────────────────────────────────────────────────────────
LOGS_DIR=./trading-logs            # Path to trade log files (JSON/NDJSON)

# ─── Node Environment ────────────────────────────────────────────────────────
NODE_ENV=development               # development | production | test
